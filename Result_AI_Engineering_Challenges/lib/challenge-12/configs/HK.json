{
  "country_code": "HK",
  "country_name": "Hong Kong",
  "rules": [
    {
      "rule_id": "HK-DOC-001",
      "description": "Medical receipt required for all claim types",
      "rule_type": "document_requirement",
      "severity": "hard",
      "parameters": { "document_type": "medical_receipt", "required_for": "all" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "HK-DOC-002",
      "description": "Referral letter required for specialist claims",
      "rule_type": "document_requirement",
      "severity": "hard",
      "parameters": { "document_type": "referral_letter", "required_for": "SPECIALIST" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "HK-DOC-003",
      "description": "Discharge summary required for inpatient claims",
      "rule_type": "document_requirement",
      "severity": "hard",
      "parameters": { "document_type": "discharge_summary", "required_for": "INPATIENT" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "HK-SLA-001",
      "description": "All claims must be processed within 20 business days",
      "rule_type": "sla_check",
      "severity": "soft",
      "parameters": { "business_days": 20, "applies_to": "all" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "HK-WAIT-001",
      "description": "General waiting period of 60 days from policy start",
      "rule_type": "waiting_period",
      "severity": "hard",
      "parameters": { "days": 60, "condition_type": "general" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "HK-WAIT-002",
      "description": "Pre-existing condition waiting period of 180 days",
      "rule_type": "waiting_period",
      "severity": "hard",
      "parameters": { "days": 180, "condition_type": "pre_existing" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "HK-MASK-001",
      "description": "HKID must be masked — show first letter and last digit only",
      "rule_type": "data_masking",
      "severity": "hard",
      "parameters": { "field": "national_id", "pattern": "X******(X)", "description": "Show first letter and last digit only" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "HK-COV-001",
      "description": "Mental health treatment must be covered at same level as physical health",
      "rule_type": "coverage_mandate",
      "severity": "hard",
      "parameters": { "applies_to": "mental_health", "condition": "claim_type === SPECIALIST && is_mental_health" },
      "effective_date": "2024-03-01"
    }
  ]
}
