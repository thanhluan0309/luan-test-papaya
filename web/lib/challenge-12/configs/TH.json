{
  "country_code": "TH",
  "country_name": "Thailand",
  "rules": [
    {
      "rule_id": "TH-DOC-001",
      "description": "Medical receipt required for all claim types",
      "rule_type": "document_requirement",
      "severity": "hard",
      "parameters": { "document_type": "medical_receipt", "required_for": "all" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "TH-DOC-002",
      "description": "Discharge summary required for inpatient claims",
      "rule_type": "document_requirement",
      "severity": "hard",
      "parameters": { "document_type": "discharge_summary", "required_for": "INPATIENT" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "TH-DOC-003",
      "description": "Prescription required for outpatient claims",
      "rule_type": "document_requirement",
      "severity": "hard",
      "parameters": { "document_type": "prescription", "required_for": "OUTPATIENT" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "TH-SLA-001",
      "description": "Outpatient claims must be processed within 15 business days",
      "rule_type": "sla_check",
      "severity": "soft",
      "parameters": { "business_days": 15, "applies_to": "OUTPATIENT" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "TH-SLA-002",
      "description": "Inpatient claims must be processed within 30 business days",
      "rule_type": "sla_check",
      "severity": "soft",
      "parameters": { "business_days": 30, "applies_to": "INPATIENT" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "TH-WAIT-001",
      "description": "General waiting period of 30 days from policy start",
      "rule_type": "waiting_period",
      "severity": "hard",
      "parameters": { "days": 30, "condition_type": "general" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "TH-WAIT-002",
      "description": "Pre-existing condition waiting period of 120 days",
      "rule_type": "waiting_period",
      "severity": "hard",
      "parameters": { "days": 120, "condition_type": "pre_existing" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "TH-MASK-001",
      "description": "National ID must be partially masked — show last 4 digits only",
      "rule_type": "data_masking",
      "severity": "hard",
      "parameters": { "field": "national_id", "pattern": "****-****-XXXX", "description": "Show last 4 digits only" },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "TH-COV-001",
      "description": "Emergency treatment must be covered regardless of network status",
      "rule_type": "coverage_mandate",
      "severity": "hard",
      "parameters": { "applies_to": "emergency", "condition": "is_emergency === true" },
      "effective_date": "2024-01-01"
    }
  ]
}
